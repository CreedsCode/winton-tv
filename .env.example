# Copy to .env and adjust as needed. .env is gitignored.

# --- v0 scaffold ---
PORT=8080
ENV=development

# --- feat/discord-oauth ---
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
