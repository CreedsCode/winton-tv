# Copy to .env and fill in. .env is gitignored.

# Server
PORT=8080
BASE_URL=http://localhost:8080     # full origin, used for OAuth redirect URL

# Discord OAuth — create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=                  # Winton guild ID (Server Settings → enable Developer Mode → right-click server)

# Postgres
DATABASE_URL=postgres://winton:winton@localhost:5432/winton?sslmode=disable

# LiveKit (V1.3)
# Generate API key/secret pair locally with:
#   docker run --rm livekit/livekit-cli generate-keys
LIVEKIT_URL=ws://localhost:7880               # backend-facing (internal in compose: ws://livekit:7880)
LIVEKIT_PUBLIC_URL=ws://localhost:7880        # browser-facing (prod: wss://livekit.your-domain)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_INGRESS_URL=http://localhost:9090     # backend-facing Twirp API (internal in compose: http://ingress:9090)

# LiveKit Ingress public URLs (only needed in prod — defaults to localhost in dev)
# INGRESS_WHIP_BASE_URL=https://ingress.your-domain/x
# INGRESS_RTMP_BASE_URL=rtmp://ingress.your-domain:1935/x
